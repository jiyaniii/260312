# ===========================================
# Vercel 배포 시: 프로젝트 설정 → Environment Variables 에서 아래 변수 추가
# ===========================================

# 팀 프로젝트 비밀번호 (설정 시 사이트 접속 시 로그인 필수)
TEAM_PASSWORD=원하는비밀번호

# 이메일 발송용 SMTP (Gmail 예시)
# Gmail: 2단계 인증 후 '앱 비밀번호' 생성하여 SMTP_PASSWORD에 입력
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Flask 세션용 (운영 시 랜덤 문자열로 변경 권장)
SECRET_KEY=random-secret-string
